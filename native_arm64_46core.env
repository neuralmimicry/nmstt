# /etc/default/nmstt
# Native on-prem arm64 Ubuntu preset for a 46-core host.

NMSTT_MODEL=/opt/nmstt/models/ggml-base.en.bin
NMSTT_BIND=127.0.0.1:7079
NMSTT_LANG=en-GB
NMSTT_THREADS=2
NMSTT_WORKERS=23
NMSTT_MAX_AUDIO_BYTES=8000000
NMSTT_BUILTIN_CONTEXT_ENABLED=1
NMSTT_PROMPT_ALLOW_CLIENT=0
NMSTT_CANONICALIZE_ENTITIES=1

# Keep the async runtime responsive under concurrent uploads.
TOKIO_WORKER_THREADS=46
RUST_LOG=info
RUST_BACKTRACE=1

# Lower-memory fallback (bigger models):
# NMSTT_THREADS=4
# NMSTT_WORKERS=11
